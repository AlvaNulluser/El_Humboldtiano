---
// BaseLayout.astro — Layout base con SEO meta tags y estilos globales
// Props: title, description, image (todas opcionales)

import "../styles/global.css";

export interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = "El Humboldtiano — Periódico Virtual UAH",
  description = "Periódico universitario de la Universidad Alejandro de Humboldt. Cultura, arte, vida universitaria y más.",
  image = "/src/assets/image-pred.jpg",
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = image.startsWith("http") ? image : new URL(image, Astro.site).href;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="website" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <title>{title}</title>

    <!-- Google Fonts: Merriweather -->
    <link
      href="https://fonts.googleapis.com/css2?family=Merriweather:wght@300;400;700;900&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
  </body>
</html>
