---
// [page].astro — Archivo paginado: 10 artículos por página
import type { GetStaticPaths, Page } from "astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";
import ArticleCard from "../../components/ArticleCard.astro";
import { getArticles, type ProcessedArticle } from "../../content/utils";

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
  const articles = await getArticles();
  articles.sort(
    (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime(),
  );
  return paginate(articles, { pageSize: 10 });
};

const { page } = Astro.props as { page: Page<ProcessedArticle> };
const pageTitle = `Archivo — Página ${page.currentPage}`;
---

<BaseLayout title={pageTitle}>
  <Header />
  <Nav />

  <main>
    <h1 class="titulo-pagina">Archivo</h1>
    <p class="subtitulo">
      Página {page.currentPage} de {page.lastPage}
      &middot; {page.total} artículos
    </p>

    {
      page.data.length === 0 ? (
        <section class="sin-articulos">
          <p>No hay artículos en esta página.</p>
        </section>
      ) : (
        <div class="cuadricula-archivo">
          {page.data.map((article) => (
            <ArticleCard article={article} />
          ))}
        </div>
      )
    }

    <nav class="paginacion" aria-label="Paginación del archivo">
      {page.currentPage > 1 ? (
        <a
          href={`/archivo/${page.currentPage - 1}`}
          class="enlace-pagina"
          rel="prev"
        >
          &larr; Anterior
        </a>
      ) : (
        <span class="enlace-pagina desactivado">&larr; Anterior</span>
      )}

      <span class="indicador-pagina">
        {page.currentPage} / {page.lastPage}
      </span>

      {page.currentPage < page.lastPage ? (
        <a
          href={`/archivo/${page.currentPage + 1}`}
          class="enlace-pagina"
          rel="next"
        >
          Siguiente &rarr;
        </a>
      ) : (
        <span class="enlace-pagina desactivado">Siguiente &rarr;</span>
      )}
    </nav>
  </main>

  <Footer />
</BaseLayout>

<style>
  main {
    max-width: 1200px;
    margin: 0 auto;
    padding: 40px 20px;
  }

  .titulo-pagina {
    font-size: 2.5rem;
    color: var(--uah-azul);
    margin-bottom: 5px;
  }

  .subtitulo {
    color: #666;
    font-size: 1rem;
    margin-bottom: 30px;
  }

  .cuadricula-archivo {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 25px;
  }

  .sin-articulos {
    text-align: center;
    padding: 60px 20px;
    color: #666;
  }

  /* ── Paginación ──────────────────────────── */
  .paginacion {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 20px;
    margin-top: 50px;
    padding-top: 30px;
    border-top: 1px solid #e2e2e2;
  }

  .enlace-pagina {
    padding: 8px 18px;
    background: var(--uah-azul);
    color: white;
    text-decoration: none;
    font-weight: 700;
    font-family: var(--fuente-sans);
    font-size: 0.9rem;
    transition: background 0.2s;
  }

  .enlace-pagina:hover {
    background: var(--uah-amarillo);
    color: var(--uah-azul);
  }

  .enlace-pagina.desactivado {
    background: #ccc;
    color: #999;
    cursor: not-allowed;
  }

  .indicador-pagina {
    font-weight: 700;
    font-size: 1rem;
    font-family: var(--fuente-sans);
  }

  @media (max-width: 768px) {
    main {
      padding: 20px 15px;
    }

    .titulo-pagina {
      font-size: 1.8rem;
    }

    .cuadricula-archivo {
      grid-template-columns: 1fr;
    }
  }
</style>
