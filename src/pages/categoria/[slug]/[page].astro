---
// [page].astro — Página de categoría paginada: 9 artículos por página
import type { GetStaticPaths, Page } from "astro";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Header from "../../../components/Header.astro";
import Nav from "../../../components/Nav.astro";
import Footer from "../../../components/Footer.astro";
import Breadcrumbs from "../../../components/Breadcrumbs.astro";
import ArticleCard from "../../../components/ArticleCard.astro";
import { getArticles, type ProcessedArticle } from "../../../content/utils";
import { CATEGORIES, slugify, deslugify } from "../../../utils/slugify";

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
  const articles = await getArticles();

  const allPaths = CATEGORIES.flatMap((cat) => {
    const filtered = articles
      .filter((a) => a.data.category === cat.name)
      .sort(
        (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime(),
      );

    // Pass slug as an additional param so paginate can generate
    // correct prev/next URLs for the multi-param route [slug]/[page].
    const results = paginate(filtered, {
      pageSize: 9,
      params: { slug: cat.slug },
    });

    return results.map((result) => ({
      params: { slug: cat.slug, page: String(result.params.page) },
      props: result.props,
    }));
  });

  return allPaths;
};

const { slug } = Astro.params;
const { page } = Astro.props as { page: Page<ProcessedArticle> };

const categoryName = deslugify(slug ?? "");
const pageTitle = `${categoryName} — El Humboldtiano`;

const breadcrumbItems = [
  { label: "Portada", href: "/" },
  { label: categoryName },
];
---

<BaseLayout title={pageTitle}>
  <Header />
  <Nav />

  <main>
    <Breadcrumbs items={breadcrumbItems} />
    <h1 class="titulo-seccion">{categoryName}</h1>

    {
      page.data.length === 0 ? (
        <section class="sin-articulos">
          <h2>Próximamente</h2>
          <p>
            Todavía no hay artículos en esta categoría. Nuestro equipo
            editorial está trabajando en nuevo contenido.
          </p>
          <a href="/rss.xml" class="enlace-rss">
            Suscribite al RSS &rarr;
          </a>
        </section>
      ) : (
        <>
          <p class="subtitulo">
            Página {page.currentPage} de {page.lastPage}
            &middot; {page.total} artículos
          </p>

          <div class="cuadricula-archivo">
            {page.data.map((article) => (
              <ArticleCard article={article} />
            ))}
          </div>

          <nav class="paginacion" aria-label="Paginación de categoría">
            {page.currentPage > 1 ? (
              <a
                href={`/categoria/${slug}/${page.currentPage - 1}`}
                class="enlace-pagina"
                rel="prev"
              >
                &larr; Anterior
              </a>
            ) : (
              <span class="enlace-pagina desactivado">&larr; Anterior</span>
            )}

            <span class="indicador-pagina">
              {page.currentPage} / {page.lastPage}
            </span>

            {page.currentPage < page.lastPage ? (
              <a
                href={`/categoria/${slug}/${page.currentPage + 1}`}
                class="enlace-pagina"
                rel="next"
              >
                Siguiente &rarr;
              </a>
            ) : (
              <span class="enlace-pagina desactivado">Siguiente &rarr;</span>
            )}
          </nav>
        </>
      )
    }
  </main>

  <Footer />
</BaseLayout>

<style>
  main {
    max-width: 1200px;
    margin: 0 auto;
    padding: 40px 20px;
  }

  .titulo-seccion {
    font-size: 2.5rem;
    color: var(--uah-azul);
    border-left: 4px solid var(--uah-amarillo);
    padding-left: 15px;
    margin-bottom: 5px;
  }

  .subtitulo {
    color: #666;
    font-size: 1rem;
    margin-bottom: 30px;
  }

  .cuadricula-archivo {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 25px;
  }

  .sin-articulos {
    text-align: center;
    padding: 60px 20px;
    color: #666;
  }

  .sin-articulos h2 {
    font-size: 2rem;
    color: var(--uah-azul);
    margin-bottom: 10px;
  }

  .sin-articulos p {
    font-size: 1.1rem;
    margin-bottom: 20px;
  }

  .enlace-rss {
    display: inline-block;
    padding: 10px 24px;
    background: var(--uah-azul);
    color: white;
    text-decoration: none;
    font-weight: 700;
    font-family: var(--fuente-sans);
    font-size: 0.9rem;
    transition: background 0.2s;
  }

  .enlace-rss:hover {
    background: var(--uah-amarillo);
    color: var(--uah-azul);
  }

  /* ── Paginación ──────────────────────────── */
  .paginacion {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 20px;
    margin-top: 50px;
    padding-top: 30px;
    border-top: 1px solid #e2e2e2;
  }

  .enlace-pagina {
    padding: 8px 18px;
    background: var(--uah-azul);
    color: white;
    text-decoration: none;
    font-weight: 700;
    font-family: var(--fuente-sans);
    font-size: 0.9rem;
    transition: background 0.2s;
  }

  .enlace-pagina:hover {
    background: var(--uah-amarillo);
    color: var(--uah-azul);
  }

  .enlace-pagina.desactivado {
    background: #ccc;
    color: #999;
    cursor: not-allowed;
  }

  .indicador-pagina {
    font-weight: 700;
    font-size: 1rem;
    font-family: var(--fuente-sans);
  }

  @media (max-width: 768px) {
    main {
      padding: 20px 15px;
    }

    .titulo-seccion {
      font-size: 1.8rem;
    }

    .cuadricula-archivo {
      grid-template-columns: 1fr;
    }
  }
</style>
